# =============================================================================
# AeroShield — Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in YOUR values in .env
#   3. NEVER commit .env to GitHub — it is listed in .gitignore
# =============================================================================

# ── Data paths ────────────────────────────────────────────────────────────────
# Folder containing your raw BTS On-Time Performance CSV files
DATA_FOLDER=C

# Folder where pipeline outputs (CSVs + charts) will be saved
OUTPUT_DIR= 

# ── PostgreSQL connection ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aeroshield
DB_USER=postgres
DB_PASSWORD= your_pass_here
